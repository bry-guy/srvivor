# Load tools/env from this project's mise.toml.
if has mise; then
  eval "$(mise env -s bash)"
fi

# Project-local fnox activation.
if has fnox; then
  if [[ -f "$HOME/.config/fnox/age.txt" ]]; then
    export FNOX_AGE_KEY="$(grep '^AGE-SECRET-KEY' "$HOME/.config/fnox/age.txt" | head -n1)"
  fi

  eval "$(fnox activate bash)"
else
  log_status "fnox not found in PATH (run: mise install)"
fi
